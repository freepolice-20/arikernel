{
  "name": "agent-firewall",
  "private": true,
  "version": "0.1.0",
  "description": "The browser security model for AI agents",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "turbo clean",
    "reset": "turbo clean && node -e \"fs.rmSync('node_modules',{recursive:true,force:true})\"",
    "cli": "node apps/cli/dist/main.js",
    "server": "node apps/server/dist/main.js",
    "server:dev": "tsx apps/server/src/main.ts",
    "demo": "tsx examples/demo.ts",
    "demo:capability": "tsx examples/demo-capability.ts",
    "demo:attack": "tsx examples/demo-attack.ts",
    "demo:escalation": "tsx examples/demo-escalation.ts",
    "demo:run-state": "tsx examples/demo-run-state.ts",
    "demo:behavioral": "tsx examples/demo-behavioral.ts",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@agent-firewall/core": "workspace:*",
    "@agent-firewall/runtime": "workspace:*",
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.3.5",
    "rimraf": "^6.1.3",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
