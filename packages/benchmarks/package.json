{
	"name": "@arikernel/benchmarks",
	"private": true,
	"version": "0.1.2",
	"description": "Reproducible attack benchmark suite for AriKernel",
	"license": "SEE LICENSE IN LICENSE.md",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/AriKernel/arikernel.git",
		"directory": "packages/benchmarks"
	},
	"homepage": "https://github.com/AriKernel/arikernel#readme",
	"bugs": {
		"url": "https://github.com/AriKernel/arikernel/issues"
	},
	"main": "dist/index.js",
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist",
		"bench": "npx tsx src/index.ts"
	},
	"dependencies": {
		"@arikernel/core": "workspace:*",
		"@arikernel/runtime": "workspace:*",
		"@arikernel/audit-log": "workspace:*",
		"@arikernel/control-plane": "workspace:*"
	},
	"devDependencies": {
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	}
}
