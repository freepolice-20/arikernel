{
	"name": "@arikernel/taint-tracker",
	"version": "0.1.2",
	"description": "Taint label tracking and propagation for AriKernel",
	"license": "SEE LICENSE IN LICENSE.md",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/AriKernel/arikernel.git",
		"directory": "packages/taint-tracker"
	},
	"homepage": "https://github.com/AriKernel/arikernel#readme",
	"bugs": {
		"url": "https://github.com/AriKernel/arikernel/issues"
	},
	"keywords": [
		"ai",
		"agent",
		"security",
		"llm",
		"tool-use",
		"taint",
		"tracking",
		"propagation",
		"data-flow",
		"provenance"
	],
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": ["dist"],
	"exports": {
