{
	"name": "@arikernel/attack-sim",
	"version": "0.1.2",
	"description": "Attack simulation pack for AriKernel",
	"license": "SEE LICENSE IN LICENSE.md",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/AriKernel/arikernel.git",
		"directory": "packages/attack-sim"
	},
	"homepage": "https://github.com/AriKernel/arikernel#readme",
	"bugs": {
		"url": "https://github.com/AriKernel/arikernel/issues"
	},
	"keywords": [
		"ai",
		"agent",
		"security",
		"llm",
		"tool-use",
		"attack",
		"simulation",
		"red-team",
		"benchmark",
		"pentest"
	],
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": ["dist", "scenarios"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"@arikernel/core": "workspace:*",
		"@arikernel/runtime": "workspace:*",
		"yaml": "^2.7.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"typescript": "^5.7.2"
	}
}
