{
	"name": "@arikernel/core",
	"version": "0.1.0",
	"description": "Core domain types and schemas for AriKernel",
	"license": "SEE LICENSE IN LICENSE.md",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/petermanrique101-sys/AriKernel.git",
		"directory": "packages/core"
	},
	"homepage": "https://github.com/petermanrique101-sys/AriKernel#readme",
	"bugs": {
		"url": "https://github.com/petermanrique101-sys/AriKernel/issues"
	},
	"keywords": ["ai", "agent", "security", "llm", "tool-use", "capability", "types", "schema"],
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": ["dist"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"ulid": "^2.3.0",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"typescript": "^5.7.2"
	}
}
