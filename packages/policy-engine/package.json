{
  "name": "@agent-firewall/policy-engine",
  "version": "0.1.0",
  "description": "Policy evaluation engine for Agent Firewall",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@agent-firewall/core": "workspace:*",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
