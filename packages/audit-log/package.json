{
	"name": "@arikernel/audit-log",
	"version": "0.1.1",
	"description": "SHA-256 hash-chained audit logging for AriKernel (tamper-evident, not tamper-proof)",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": ["dist"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"@arikernel/core": "workspace:*",
		"better-sqlite3": "^11.7.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.12",
		"typescript": "^5.7.2"
	}
}
