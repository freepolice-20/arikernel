{
	"name": "@arikernel/mcp-adapter",
	"private": true,
	"version": "0.1.0",
	"description": "MCP adapter for AriKernel — mediate MCP tool calls through the enforcement pipeline",
	"license": "Apache-2.0",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/petermanrique101-sys/AriKernel.git",
		"directory": "packages/mcp-adapter"
	},
	"homepage": "https://github.com/petermanrique101-sys/AriKernel#readme",
	"bugs": {
		"url": "https://github.com/petermanrique101-sys/AriKernel/issues"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"@arikernel/core": "workspace:*",
		"@arikernel/runtime": "workspace:*",
		"@arikernel/tool-executors": "workspace:*"
	},
	"devDependencies": {
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	}
}
