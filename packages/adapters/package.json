{
  "name": "@arikernel/adapters",
  "version": "0.1.0",
  "description": "Framework adapters for AriKernel — protect agents built with LangChain, CrewAI, OpenAI, and more",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./langchain": {
      "types": "./dist/langchain.d.ts",
      "import": "./dist/langchain.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/langchain.ts --format esm --dts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@arikernel/core": "workspace:*",
    "@arikernel/runtime": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
