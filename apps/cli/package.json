{
  "name": "@arikernel/cli",
  "version": "0.1.0",
  "description": "CLI for AriKernel",
  "type": "module",
  "bin": {
    "arikernel": "dist/main.js"
  },
  "scripts": {
    "build": "tsup src/main.ts --format esm --dts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@arikernel/core": "workspace:*",
    "@arikernel/runtime": "workspace:*",
    "@arikernel/policy-engine": "workspace:*",
    "@arikernel/audit-log": "workspace:*",
    "@arikernel/attack-sim": "workspace:*",
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
