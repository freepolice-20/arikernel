{
	"name": "@arikernel/cli",
	"version": "0.1.2",
	"description": "Runtime security layer for AI agents. Enforces policy on tool calls to block prompt injection and unsafe actions.",
	"type": "module",
	"license": "SEE LICENSE IN LICENSE.md",
	"bin": {
		"arikernel": "dist/main.js"
	},
	"files": ["dist"],
	"repository": {
		"type": "git",
		"url": "https://github.com/AriKernel/arikernel.git",
		"directory": "apps/cli"
	},
	"homepage": "https://github.com/AriKernel/arikernel#readme",
	"bugs": {
		"url": "https://github.com/AriKernel/arikernel/issues"
	},
	"keywords": [
		"ai",
		"ai-agents",
		"ai-security",
		"agent-security",
		"prompt-injection",
		"runtime-security",
		"tool-safety",
		"taint-tracking",
		"sandbox",
		"llm"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"better-sqlite3": "^11.0.0",
		"citty": "^0.1.6",
		"ulid": "^2.4.0",
		"yaml": "^2.8.0",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@arikernel/core": "workspace:*",
		"@arikernel/runtime": "workspace:*",
		"@arikernel/policy-engine": "workspace:*",
		"@arikernel/audit-log": "workspace:*",
		"@arikernel/attack-sim": "workspace:*",
		"@arikernel/benchmarks": "workspace:*",
		"@arikernel/control-plane": "workspace:*",
		"@arikernel/sidecar": "workspace:*",
		"typescript": "^5.7.2"
	}
}
