{
	"name": "@arikernel/cli",
	"version": "0.1.0",
	"description": "CLI for Ari Kernel — enforces security policy at the AI agent tool execution boundary",
	"type": "module",
	"license": "SEE LICENSE IN LICENSE.md",
	"bin": {
		"arikernel": "dist/main.js"
	},
	"files": ["dist"],
	"repository": {
		"type": "git",
		"url": "https://github.com/petermanrique101-sys/AriKernel.git",
		"directory": "apps/cli"
	},
	"homepage": "https://github.com/petermanrique101-sys/AriKernel#readme",
	"bugs": {
		"url": "https://github.com/petermanrique101-sys/AriKernel/issues"
	},
	"keywords": [
		"ai",
		"agent",
		"security",
		"firewall",
		"llm",
		"tool-use",
		"capability",
		"audit",
		"taint-tracking",
		"reference-monitor"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup src/main.ts --format esm --dts",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"@arikernel/core": "workspace:*",
		"@arikernel/runtime": "workspace:*",
		"@arikernel/policy-engine": "workspace:*",
		"@arikernel/audit-log": "workspace:*",
		"@arikernel/attack-sim": "workspace:*",
		"@arikernel/benchmarks": "workspace:*",
		"@arikernel/control-plane": "workspace:*",
		"@arikernel/sidecar": "workspace:*",
		"citty": "^0.1.6"
	},
	"devDependencies": {
		"typescript": "^5.7.2"
	}
}
