{
	"name": "@arikernel/server",
	"version": "0.1.2",
	"description": "HTTP decision server for AriKernel",
	"license": "SEE LICENSE IN LICENSE.md",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/AriKernel/arikernel.git",
		"directory": "apps/server"
	},
	"homepage": "https://github.com/AriKernel/arikernel#readme",
	"bugs": {
		"url": "https://github.com/AriKernel/arikernel/issues"
	},
	"scripts": {
		"build": "tsup src/main.ts --format esm --dts",
		"start": "node dist/main.js",
		"dev": "tsx src/main.ts",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"@arikernel/core": "workspace:*",
		"@arikernel/runtime": "workspace:*"
	},
	"devDependencies": {
		"typescript": "^5.7.2"
	}
}
